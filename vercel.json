{
    "version": 2,
    "outputDirectory": "frontend",
    "builds": [
        {
            "src": "frontend/api/proxy.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/proxy(.*)",
            "dest": "/frontend/api/proxy.js"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/$1"
        }
    ]
}
